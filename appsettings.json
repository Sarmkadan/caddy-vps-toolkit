{
  "Caddy": {
    "AdminPort": 2019,
    "AdminHost": "localhost",
    "HttpPort": 80,
    "HttpsPort": 443,
    "AdminEmail": "admin@example.com",
    "CertificateEmail": "admin@example.com",
    "EnableMetrics": true,
    "EnableLogOutput": true,
    "LogLevel": "info"
  },
  "HealthCheck": {
    "Enabled": true,
    "DefaultIntervalSeconds": 30,
    "DefaultTimeoutSeconds": 5,
    "DefaultUnhealthyThreshold": 3,
    "DefaultHealthyThreshold": 2,
    "CleanupDaysToKeep": 30
  },
  "Services": {
    "DefaultPort": 8080,
    "DefaultUser": "root",
    "AutoStartEnabled": false,
    "DefaultPriority": 50
  },
  "Systemd": {
    "UnitDirectory": "/etc/systemd/system",
    "CommandTimeoutSeconds": 10
  },
  "Logging": {
    "Level": "info",
    "Format": "{common_log}",
    "EnableConsoleLogging": true,
    "LogDirectory": "/var/log/caddy-vps-toolkit"
  },
  "Database": {
    "Path": "/var/lib/caddy-vps-toolkit/services.db",
    "EnableBackups": true,
    "BackupRetentionDays": 7
  }
}
